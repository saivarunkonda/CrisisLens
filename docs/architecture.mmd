flowchart LR
  subgraph Browser
    U[User / Analyst]
  end

  subgraph Frontend
    N["Next.js App<br/>(App Router + NextAuth)"]
  end

  subgraph Backend
    API[Next.js API Routes]
    ML[FastAPI ML Service]
  end

  subgraph Datastores
    S["Supabase (Postgres)<br/>reports, users, risk_snapshots, ml_models"]
    M["MongoDB<br/>(raw_reports, replication_queue)"]
  end

  subgraph Infra
    EKS["EKS Cluster / Kubeflow"]
    S3["S3 Training Bucket"]
    GH["GitHub Actions CI"]
    TF["Terraform / eksctl"]
  end

  U -->|browser| N
  N -->|auth & api| API
  API -->|reads/writes| S
  API -->|replicate writes| M
  API -->|trigger retrain| EKS
  ML -->|reads raw payloads| M
  ML -->|writes artifacts / training data| S3
  GH -->|seed / ETL / upload| S3
  GH -->|build & push trainer| GHCR[GHCR Registry]
  GH -->|call retrain endpoint| API
  TF -->|provision| EKS
  TF -->|create| S3
  EKS -->|runs| ML
  EKS -->|runs| Cron[flush-replication CronJob]

  %% Secrets (placeholders only)
  classDef secrets fill:#ffe4b5,stroke:#cc9900;
  subgraph Secrets ["Secrets - DO NOT COMMIT"]
    SEC1["SUPABASE_SERVICE_ROLE_KEY<br/>(server-only)"]:::secrets
    SEC2["NEXT_PUBLIC_SUPABASE_URL<br/>(client-ok)"]:::secrets
    SEC3["MONGODB_URI<br/>(server-only)"]:::secrets
    SEC4["AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY<br/>(CI/provision)"]:::secrets
    SEC5["S3_BUCKET<br/>(CI/config)"]:::secrets
    SEC6["GHCR_TOKEN<br/>(CI->push image)"]:::secrets
    SEC7["DEPLOY_KEY<br/>(API auth for retrain)"]:::secrets
    SEC8["INTERNAL_API_KEY<br/>(flush endpoint)"]:::secrets
  end

  SEC1 --> S
  SEC2 --> N
  SEC3 --> M
  SEC4 --> GH
  SEC5 --> GH
  SEC6 --> GH
  SEC7 --> API
  SEC8 --> Cron

  title CrisisLens: Architecture (Supabase primary, Mongo for ML, S3 for artifacts)
