# ===========================================
# CRISISLENS ENVIRONMENT VARIABLES
# Copy this to .env.local for local development
# ===========================================

# Required for Auth.js / NextAuth (generate: openssl rand -base64 32)
AUTH_SECRET=

# App URL (optional locally; set in production)
AUTH_URL=http://localhost:3000

# ===========================================
# OAUTH PROVIDERS (Optional - Enhanced Login)
# ===========================================
# Google OAuth - Get from: https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth - Get from: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# RBAC for OAuth users (comma-separated emails, lowercase)
# ADMIN_EMAILS=you@gmail.com,admin@yourcompany.com
# ANALYST_EMAILS=colleague@gmail.com,staff@yourcompany.com

# ===========================================
# DATABASE (Required)
# ===========================================
# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# EXTERNAL APIS (Optional - Full Intelligence)
# ===========================================
# Weather Data - Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Emergency Services - Configure your emergency API
EMERGENCY_API_KEY=
EMERGENCY_API_URL=https://api.emergency-services.gov

# News Monitoring - Get from: https://newsapi.org
NEWS_API_KEY=

# Social Media Intelligence - Configure your social API
SOCIAL_MEDIA_API_KEY=
SOCIAL_MEDIA_API_URL=https://api.social-monitor.com

# ===========================================
# MACHINE LEARNING (Optional)
# ===========================================
# ML inference (FastAPI)
ML_SERVICE_URL=http://localhost:8000

# Kubeflow Pipelines REST (optional — retrain button)
# KFP_API_BASE_URL=https://your-kubeflow.example.com/pipeline
# KFP_PIPELINE_ID=
# KFP_PIPELINE_VERSION_ID=
# KFP_BEARER_TOKEN=

# ===========================================
# INFRASTRUCTURE (Optional)
# ===========================================
# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET=crisislens-training-data
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===========================================
# PAYMENT SYSTEM (Optional)
# ===========================================
# Stripe Configuration - Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Auth Backend (keep "supabase" for production)
AUTH_BACKEND=supabase

# Node Environment
NODE_ENV=development
